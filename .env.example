# kimi-appalti — nomi delle variabili d'ambiente (senza valori)
# Le chiavi vivono solo in variabili d'ambiente locali. Mai nel repository.

# Vercel AI Gateway (accesso a moonshotai/kimi-k2.6 e al modello Claude baseline)
AI_GATEWAY_API_KEY=

# Stringhe modello pinnate (versioni fissate per riproducibilità)
KIMI_MODEL=moonshotai/kimi-k2.6
CLAUDE_BASELINE_MODEL=

# Zero Data Retention: attivare dove il Gateway lo consente
