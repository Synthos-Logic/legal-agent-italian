# kimi-appalti — nomi delle variabili d'ambiente (senza valori)
# Le chiavi vivono solo in variabili d'ambiente locali. Mai nel repository.

# Via di default: Vercel AI Gateway (modello zai/glm-5.2, vedi eval/harness/models.json)
AI_GATEWAY_API_KEY=

# Fallback attivabile via models.json (endpoint https://api.z.ai/api/paas/v4/chat/completions,
# modello glm-5.2) — valutare ZDR/termini prima dell'uso
ZAI_API_KEY=

# Endpoint locali (es. Ollama, http://localhost:11434/v1/chat/completions): nessuna chiave
# necessaria — impostare "api_key_env": null in models.json.
